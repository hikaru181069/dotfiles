return {
  {
    "dstein64/nvim-scrollview",
    event = { "BufReadPost", "BufNewFile" },
    config = function()
      vim.g.scrollview_current_only = true
      vim.g.scrollview_base = "right"
      vim.g.scrollview_column = 1
      vim.g.scrollview_signs_on_startup = { "diagnostics", "search", "marks" }
    end,
  },
}
