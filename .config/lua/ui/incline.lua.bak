return {
  {
    "b0o/incline.nvim",
    event = "VeryLazy",
    config = function()
      local devicons = require("nvim-web-devicons")

      require("incline").setup({
        window = {
          margin = {
            horizontal = 1,
            vertical = 1,
          },
          padding = 0,
          placement = {
            horizontal = "right",
            vertical = "top",
          },
          zindex = 50,
        },
        hide = {
          cursorline = false,
        },
        render = function(props)
          local filename = vim.fn.fnamemodify(vim.api.nvim_buf_get_name(props.buf), ":t")
          if filename == "" then
            filename = "[No Name]"
          end

          local ft = vim.bo[props.buf].filetype
          local icon, color = devicons.get_icon_color(filename)

          return {
            { " " },
            icon and { icon, guifg = color } or "",
            icon and { " " } or "",
            { filename },
            ft ~= "" and { " 󰈙 " .. ft, gui = "italic" } or "",
            { " " },
          }
        end,
      })
    end,
  },
}
